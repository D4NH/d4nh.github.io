[{"_path":"/duitsland-2016/day-1-zwarte-woud","_dir":"duitsland-2016","_draft":false,"_partial":false,"_locale":"","title":"Day 1 - Zwarte Woud","description":"Rond 8.00 vertrokken wij naar het oosten van het land. We hadden afgesproken om elkaar te ontmoeten bij de laatste tankstation voor de grens.","date":"2016-07-25","image":"https://www.danhnguyen.nl/wp-content/uploads/20160725_175249-e1470213649194.jpg","category":"Zwarte woud - Duitsland","intro":"Lekker een weekje er tussen uit met vrienden. Dit keer naar het zuiden van Duitsland, Zwarte-woud. Lekker kamperen met een tent. Nou ja, wel luxe dan, op de tent na.","body":{"type":"root","children":[{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Rond 8.00 vertrokken wij naar het oosten van het land. We hadden afgesproken om elkaar te ontmoeten bij de laatste tankstation voor de grens."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"img","props":{"alt":"Screen Shot 2016-08-03 at 10.17.47","class":"img-fluid rounded-3 shadow-sm","src":"https://www.danhnguyen.nl/wp-content/uploads/Screen-Shot-2016-08-03-at-10.17.47-e1470212366661.png"},"children":[]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Alright, tijd om de grens over te steken en richting het zuiden van Duitsland te rijden."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"img","props":{"alt":"20160725_134546","class":"img-fluid rounded-3 shadow-sm","src":"https://www.danhnguyen.nl/wp-content/uploads/20160725_134546-e1470215146933.jpg"},"children":[]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Ondertussen nog even een korte stop gemaakt om lekker te lunchen."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"img","props":{"alt":"20160725_132105","class":"img-fluid rounded-3 shadow-sm","src":"https://www.danhnguyen.nl/wp-content/uploads/20160725_132105-e1470212514703.jpg"},"chil