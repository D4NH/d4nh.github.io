2435-e1470215025424.jpg"},"children":[]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"De rest van de avond lekker gechillt."}]}],"toc":{"title":"","searchDepth":2,"depth":2,"links":[]}},"_type":"markdown","_id":"content:duitsland-2016:day-1-zwarte-woud.md","_source":"content","_file":"duitsland-2016/day-1-zwarte-woud.md","_extension":"md"},{"_path":"/duitsland-2016/day-2-bad-wildbad","_dir":"duitsland-2016","_draft":false,"_partial":false,"_locale":"","title":"Day 2 - Bad Wildbad","description":"Hmm.. heb toch best goed geslapen. Niet verwacht van een tentje. We hadden dan ook een luchtbed, maar hey, we sliepen buiten! ","date":"2016-07-26","image":"https://www.danhnguyen.nl/wp-content/uploads/20160726_095627-e1470215748304.jpg","category":"Zwarte woud - Duitsland","body":{"type":"root","children":[{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Hmm.. heb toch best goed geslapen. Niet verwacht van een tentje. We hadden dan ook een luchtbed, maar hey, we sliepen buiten! "}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"img","props":{"alt":"20160726_095627","class":"img-fluid rounded-3 shadow-sm","src":"https://www.danhnguyen.nl/wp-content/uploads/20160726_095627-e1470215748304.jpg"},"children":[]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Na een ontbijt van de overgebleven broodjes zijn we richting Bad Wildbad gereden."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"img","props":{"alt":"clone tag: -6354653342601908788","class":"img-fluid rounded-3 shadow-sm","src":"https://www.danhnguyen.nl/wp-content/uploads/20160726_104352-e1470215904581.jpg"},"children":[]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Mooi uitzicht, op de wolken na dan. Even zoeken wat je hier kunt doen."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"img","props":{"alt":"DSC00219